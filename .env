# Committed defaults — safe to version-control.
# Put real secrets (e.g. GEMINI_API_KEY) in .env.local (gitignored).

export GEMINI_API_KEY=

# JWT secrets — must be at least 32 chars each
export JWT_SIGNING_SECRET=changeMeInProductionSigningSecret32c
export JWT_ENCRYPTION_SECRET=changeMeInProductionEncryptionSec

# Database (defaults match docker-compose.yml)
export DB_URL=jdbc:postgresql://localhost:5432/docuro
export DB_USER=docuro
export DB_PASSWORD=docuro

# MinIO / S3 (defaults match docker-compose.yml)
export MINIO_ENDPOINT=http://localhost:9000
export STORAGE_BUCKET=docuro-documents
